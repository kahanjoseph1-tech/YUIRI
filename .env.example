# Firebase Client SDK (public, exposed to browser)
NEXT_PUBLIC_FIREBASE_API_KEY=your-api-key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=000000000000
NEXT_PUBLIC_FIREBASE_APP_ID=1:000000000000:web:your-app-id

# Firebase Admin SDK (server-side only, keep secret)
# Firebase Functions reserves the FIREBASE_ prefix, so use FB_ADMIN_* for deploys.
FB_ADMIN_PROJECT_ID=your-project-id
FB_ADMIN_CLIENT_EMAIL=firebase-adminsdk@your-project.iam.gserviceaccount.com
FB_ADMIN_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY\n-----END PRIVATE KEY-----\n"

# Local-only fallback: you can also use Google application credentials locally.
GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/service-account.json

# Seed endpoint
SEED_SECRET=change-this-before-public-use

# NextAuth
NEXTAUTH_SECRET=your-secret-here
NEXTAUTH_URL=http://localhost:3000
