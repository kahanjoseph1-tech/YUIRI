rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function currentUserPath() {
      return /databases/$(database)/documents/users/$(request.auth.uid);
    }

    function currentUserIsApproved() {
      return signedIn()
        && exists(currentUserPath())
        && get(currentUserPath()).data.approval_status in ["approved", "Approved"];
    }

    function currentUserIsAdmin() {
      return currentUserIsApproved()
        && get(currentUserPath()).data.crm_role in ["admin", "Admin"];
    }

    function isBootstrapAdmin() {
      return signedIn() && request.auth.token.email == "kahanjoseph1@gmail.com";
    }

    function validUserCreate(userId) {
      return signedIn()
        && request.auth.uid == userId
        && !exists(/databases/$(database)/documents/users/$(userId))
        && request.resource.data.keys().hasOnly([
          "email",
          "full_name",
          "name",
          "crm_role",
          "firebase_uid",
          "approval_status",
          "created_date",
          "updated_date"
        ])
        && request.resource.data.firebase_uid == request.auth.uid
        && request.resource.data.email == request.auth.token.email
        && (
          (
            isBootstrapAdmin()
            && request.resource.data.crm_role == "admin"
            && request.resource.data.approval_status == "approved"
          )
          ||
          (
            request.resource.data.crm_role == "user"
            && request.resource.data.approval_status == "pending"
          )
        );
    }

    function validUserUpdate() {
      return request.resource.data.crm_role in ["admin", "user", "Admin", "User"]
        && request.resource.data.approval_status in ["approved", "pending", "Approved", "Pending"];
    }

    match /users/{userId} {
      allow get: if currentUserIsApproved() || (signedIn() && request.auth.uid == userId);
      allow list: if currentUserIsApproved();
      allow create: if validUserCreate(userId);
      allow update: if currentUserIsAdmin() && validUserUpdate();
      allow delete: if currentUserIsAdmin();
    }

    match /settings/{document} {
      allow read: if currentUserIsApproved();
      allow write: if currentUserIsAdmin();
    }

    match /clients/{document} {
      allow read, write: if currentUserIsApproved();
    }

    match /appointments/{document} {
      allow read, write: if currentUserIsApproved();
    }

    match /appointment_availability/{document} {
      allow read, write: if currentUserIsApproved();
    }

    match /evaluations/{document} {
      allow read, write: if currentUserIsApproved();
    }

    match /open_cases/{document} {
      allow read, write: if currentUserIsApproved();
    }

    match /follow_ups/{document} {
      allow read, write: if currentUserIsApproved();
    }

    match /billing/{document} {
      allow read, write: if currentUserIsApproved();
    }

    match /financials/{document} {
      allow read, write: if currentUserIsApproved();
    }

    match /schools/{document} {
      allow read, write: if currentUserIsApproved();
    }

    match /placements/{document} {
      allow read, write: if currentUserIsApproved();
    }
  }
}
